<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Đếm Tiền</title>

<style>
body{
    margin:0;
    font-family:-apple-system,BlinkMacSystemFont,sans-serif;
    background:#111827;
    color:#fff;
}

.container{
    max-width:430px;
    margin:auto;
    padding:20px;
}

h1{
    text-align:center;
}

.card{
    background:#1f2937;
    border-radius:15px;
    padding:12px;
    margin-bottom:10px;
    display:flex;
    justify-content:space-between;
    align-items:center;
}

input{
    width:70px;
    font-size:18px;
    text-align:center;
    border:none;
    border-radius:10px;
    padding:8px;
}

button{
    width:35px;
    height:35px;
    font-size:22px;
    border:none;
    border-radius:50%;
    background:#2563eb;
    color:white;
}

.total{
    margin-top:25px;
    background:#059669;
    border-radius:18px;
    padding:20px;
    text-align:center;
}

.money{
    font-size:36px;
    font-weight:bold;
}

.reset{
    width:100%;
    height:50px;
    margin-top:20px;
    border-radius:15px;
    background:#ef4444;
    font-size:18px;
}
</style>

</head>
<body>

<div class="container">

<h1>💰 Đếm Tiền</h1>

<div id="list"></div>

<div class="total">
<div>Tổng số tờ</div>
<h2 id="paper">0</h2>

<div>Tổng tiền</div>
<div class="money" id="money">0 ₫</div>
</div>

<button class="reset" onclick="resetAll()">Reset</button>

</div>

<script>

const bills=[1000,2000,5000,10000,20000,50000,100000,200000,500000];

const list=document.getElementById("list");

bills.forEach(v=>{

list.innerHTML+=`
<div class="card">
<div>${v.toLocaleString("vi-VN")}đ</div>

<div>
<button onclick="change(${v},-1)">-</button>

<input id="${v}" type="number" value="${localStorage.getItem(v)||0}" oninput="save()">

<button onclick="change(${v},1)">+</button>
</div>

</div>
`;

});

function change(id,n){

let input=document.getElementById(id);

let x=parseInt(input.value)||0;

x+=n;

if(x<0)x=0;

input.value=x;

save();

}

function save(){

let total=0;

let paper=0;

bills.forEach(v=>{

let x=parseInt(document.getElementById(v).value)||0;

localStorage.setItem(v,x);

paper+=x;

total+=x*v;

});

document.getElementById("paper").innerText=paper;

document.getElementById("money").innerText=total.toLocaleString("vi-VN")+" ₫";

}

function resetAll(){

if(confirm("Xóa tất cả?")){

bills.forEach(v=>{

document.getElementById(v).value=0;

localStorage.removeItem(v);

});

save();

}

}

save();

</script>

</body>
</html>
